# =============================================================================
# Olympus Engine v9 — Environment configuration (EXAMPLE)
# =============================================================================
# Copy this file to `.env` and adjust for your local dev environment.
# NEVER commit a real `.env` to version control — `.gitignore` already
# excludes it.
# =============================================================================

# ---------- Database ----------
POSTGRES_PASSWORD=olympus
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=olympus
POSTGRES_DB=olympus
PGBOUNCER_PORT=6432

# ---------- Redis ----------
REDIS_PASSWORD=
REDIS_MASTER=redis://localhost:6379/0
REDIS_SENTINEL=localhost:26379

# ---------- HSM ----------
# Mode: mock | pkcs11
OLYMPUS_HSM_MODE=mock
OLYMPUS_MOCK_HSM_PIN=0000
OLYMPUS_MOCK_HSM_SEEDED=0

# Real HSM (only when OLYMPUS_HSM_MODE=pkcs11)
# OLYMPUS_HSM_LIB=/usr/lib/softhsm/libsofthsm2.so
# OLYMPUS_HSM_SLOT=0
# OLYMPUS_HSM_PIN=

# ---------- Vault ----------
OLYMPUS_VAULT_URL=http://localhost:8200
VAULT_TOKEN=olympus-dev-token
OLYMPUS_VAULT_PII_SALT_PATH=secret/data/olympus/pii/salt

# ---------- AI ----------
# Mode: mock | onnx
OLYMPUS_AI_MODE=mock
OLYMPUS_GPU_DEVICES=0,1

# ---------- App ----------
OLYMPUS_ENV=development
OLYMPUS_LOG_LEVEL=INFO
OLYMPUS_BIND=0.0.0.0:8000
OLYMPUS_MAX_UPLOAD_SIZE_MB=10
OLYMPUS_DEBUG=false

# ---------- JWT / Session ----------
OLYMPUS_JWT_SECRET=change-me-in-prod-this-is-only-for-dev
OLYMPUS_SESSION_TTL_SECONDS=3600

# ---------- Frontend ----------
VITE_API_URL=
VITE_BACKEND_URL=http://localhost:8000

# ---------- Grafana ----------
GRAFANA_PASSWORD=admin

# ---------- TLS (dev only — use Step CA in prod) ----------
TLS_DEV_CERT_PATH=./certs/dev.crt
TLS_DEV_KEY_PATH=./certs/dev.key
TLS_DEV_CA_PATH=./certs/dev-ca.crt
